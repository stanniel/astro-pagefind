---
import { ClientRouter } from "astro:transitions";
import path from "node:path";
import Search from "../components/Search.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Search API example",
  description = "Example of using @stanniel/astro-pagefind with the Pagefind Search API",
} = Astro.props;

const base = import.meta.env.BASE_URL;
const routes = ["", "books", "/tech-support", "/space"].map((r) =>
  path.posix.join(base, r),
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="generator" content={Astro.generator}>
    <title>{title}</title>
    <meta name="title" content={title}>
    <meta name="description" content={description}>
    <link rel="stylesheet" href={`${base}global.css`}>
    <ClientRouter />
  </head>
  <body>
    <main>
      <nav>
        <ul>
          {routes.map(r => <li><a href={r}>{r}</a></li>)}
        </ul>
      </nav>
      <h4>Example: Using Pagefind's Search API to make your own UI</h4>
      <Search />
      <slot />
    </main>
  </body>
</html>
